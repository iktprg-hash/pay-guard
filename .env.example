# =============================================================================
# Pay Guard — environment variables
# =============================================================================
#
# Lokálně:  cp .env.example .env.local   → vyplňte hodnoty
# Vercel:   Settings → Environment Variables → Production (viz DEPLOY.md)
#
# Legenda:
#   [PROD]     povinné na Vercel Production
#   [STRIPE]   povinné pro Pro checkout / webhook
#   [DEV]      pouze lokální vývoj — NIKDY na Vercel Production
#   [OPTIONAL] volitelné (mají rozumné defaulty)
#   [SCRIPTS]  pouze npm skripty / CI — není potřeba ve Vercel runtime
#
# =============================================================================

# --- [PROD] Veřejná URL aplikace -----------------------------------------------
# Checkout redirect, auth e-maily, metadata. Po deployi nastavte na skutečnou doménu.
# Příklad: https://pay-guard-murex-alpha.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# --- [PROD] Supabase -----------------------------------------------------------
# Dashboard → Project → Settings → API
# https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_service_role_key

# --- [PROD] Upstash Redis — rate limits (fail-closed bez těchto klíčů) --------
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXAAIncDEexampleUpstashTokenValue0123456789abcdef

# --- [PROD] xAI Grok — chat a prioritizace ------------------------------------
# https://console.x.ai/
# Bez klíče: v dev demo/mock; v produkci doporučeno nastavit.
XAI_API_KEY=xai-example_key_replace_with_real_value_from_console

# --- [OPTIONAL] Grok model (default: grok-3-mini) ----------------------------
# XAI_MODEL=grok-3-mini

# =============================================================================
# [STRIPE] Pro billing — český trh (CZK / month)
# =============================================================================
# Dashboard → Products → recurring Price v CZK → price_…
# Webhook URL: https://<your-domain>/api/webhooks/stripe

# Formát: sk_live_… nebo sk_test_… (Stripe Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRO_PRICE_ID=your_stripe_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Signing secret — použijte JEDNU z variant (formát whsec_…):
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...   # doporučeno pro Production
# STRIPE_WEBHOOK_SECRET_TEST=whsec_...   # volitelně pro Preview deploye

# =============================================================================
# [OPTIONAL] Production — kurzy pro Pro currency conversion
# =============================================================================
# Výchozí hodnoty jsou v kódu; přepište jen při potřebě.
# CZK_RATE_EUR=25.2
# CZK_RATE_USD=23.1
# CZK_RATE_GBP=29.4
# CZK_RATE_RUB=0.27
# CZK_RATE_UAH=0.58
# CZK_RATE_PLN=5.85

# =============================================================================
# [DEV] Lokální vývoj — NIKDY na Vercel Production
# =============================================================================

# Obchází Supabase e-mail při registraci (vyžaduje SUPABASE_SERVICE_ROLE_KEY)
# AUTH_DEV_REGISTER=1

# Vypne auth rate limit v dev (pouze NODE_ENV=development)
# AUTH_SKIP_RATE_LIMIT=1

# =============================================================================
# [SCRIPTS] Migrace, zálohy, E2E — není potřeba ve Vercel runtime
# =============================================================================

# npm run db:apply / db:backup
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=dwllmawtufyymlcbsblt

# Lokální DB zálohy (npm run db:backup → ~/PayGuard-backups)
# BACKUP_DIR=/Users/you/PayGuard-backups
# BACKUP_RETAIN_DAYS=30

# E2E testy — viz .env.test.example
# E2E_BASE_URL=http://127.0.0.1:3000
# E2E_NO_WEBSERVER=1
# E2E_FREE_USER_EMAIL=e2e-free@pay-guard.test
# E2E_FREE_USER_PASSWORD=E2eTestPass1

# =============================================================================
# Supabase Auth — URL Configuration (Dashboard, ne env)
# =============================================================================
# Dev Site URL:     http://127.0.0.1:3000
# Dev Redirect:     http://127.0.0.1:3000/auth/confirm
# Prod Site URL:    https://<your-domain>
# Prod Redirects:   https://<your-domain>/auth/confirm
#                   https://<your-domain>/auth/callback
#                   https://<your-domain>/**
