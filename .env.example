# Pay Guard — environment variables reference
# Copy to `.env.local` for local dev:  cp .env.example .env.local
# Vercel: Project → Settings → Environment Variables → Production (see DEPLOY.md)

# =============================================================================
# REQUIRED — Production (Vercel)
# =============================================================================

# Public site URL (checkout redirects, auth emails, metadata)
# Example: https://pay-guard-xxxx.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Supabase — https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Upstash Redis — rate limits in production (required; fail-closed without it)
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# xAI Grok — chat & prioritization (without key: demo/mock mode in dev only)
# https://console.x.ai/
XAI_API_KEY=your_xai_api_key

# =============================================================================
# REQUIRED — Production (Stripe Pro billing, CZK)
# =============================================================================

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PRO_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Webhook signing secret — use ONE of:
#   STRIPE_WEBHOOK_SECRET          (legacy, single env)
#   STRIPE_WEBHOOK_SECRET_LIVE     (recommended for production)
#   STRIPE_WEBHOOK_SECRET_TEST     (optional, Preview deployments)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_xxx
# STRIPE_WEBHOOK_SECRET_TEST=whsec_xxx

# Webhook URL in Stripe Dashboard:
#   https://<your-domain>/api/webhooks/stripe

# =============================================================================
# OPTIONAL — Production
# =============================================================================

# Grok model (default: grok-3-mini)
# XAI_MODEL=grok-3-mini

# FX rates for Pro currency conversion (defaults built-in if unset)
# CZK_RATE_EUR=25.2
# CZK_RATE_USD=23.1
# CZK_RATE_GBP=29.4
# CZK_RATE_RUB=0.27
# CZK_RATE_UAH=0.58
# CZK_RATE_PLN=5.85

# =============================================================================
# LOCAL DEV ONLY — never set on Vercel Production
# =============================================================================

# Skip Supabase email on password register (requires service role key)
# AUTH_DEV_REGISTER=1

# Bypass auth rate limits in development only
# AUTH_SKIP_RATE_LIMIT=1

# =============================================================================
# SCRIPTS / CI ONLY — not needed in Vercel runtime
# =============================================================================

# npm run db:apply / db:backup
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_ACCESS_TOKEN=sbp_...

# Local DB backups (npm run db:backup)
# BACKUP_DIR=/Users/you/PayGuard-backups
# BACKUP_RETAIN_DAYS=30

# E2E tests — see .env.test.example
# E2E_BASE_URL=http://127.0.0.1:3000
# E2E_FREE_USER_EMAIL=e2e-free@pay-guard.test
# E2E_FREE_USER_PASSWORD=E2eTestPass1

# Supabase Auth (Dashboard → Authentication → URL Configuration)
# Local redirect: http://127.0.0.1:3000/auth/confirm
# Production redirect: https://<your-domain>/auth/confirm
