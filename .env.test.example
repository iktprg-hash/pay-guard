# Pay Guard E2E — copy values to .env.local or export before `npm run test:e2e`

# App URL (must match `npm run dev` host — default 127.0.0.1:3000)
E2E_BASE_URL=http://127.0.0.1:3000
E2E_LOCALE=cs

# --- testUserCredentials (free-tier E2E account) ---
# Created automatically in tests/auth.setup.ts when missing (login → register fallback)
E2E_FREE_USER_EMAIL=e2e-free@pay-guard.test
E2E_FREE_USER_PASSWORD=E2eTestPass1

# Required for idempotent register in local dev (see .env.local.example)
AUTH_DEV_REGISTER=1

# Skip Playwright auto-start of `npm run dev` when the app is already running
# npm run test:e2e:local
E2E_NO_WEBSERVER=1

# CI filters (optional)
# E2E_GREP=checkout
# E2E_GREP_INVERT=skip

# Supabase + Stripe (same as local dev — checkout E2E skips if Stripe is not configured)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRO_PRICE_ID=price_...
