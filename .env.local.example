# Pay Guard — local development template
# Setup:  cp .env.local.example .env.local
# Full reference with prod/dev labels: .env.example
# Deploy guide: DEPLOY.md

NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-3-mini

# Stripe — formát: sk_test_… / pk_test_… (Dashboard → API keys)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRO_PRICE_ID=your_stripe_price_id
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Dev-only — do NOT add to Vercel Production
# AUTH_DEV_REGISTER=1
# AUTH_SKIP_RATE_LIMIT=1
