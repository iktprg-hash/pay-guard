# Pay Guard — local development
# Setup:  cp .env.local.example .env.local   (or: cp .env.example .env.local)
# Full reference: .env.example  |  Deploy guide: DEPLOY.md

# --- Required for local app + prod:checklist ---

NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-3-mini

# Stripe (use sk_test_… locally; sk_live_… only if you know what you’re doing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Local dev helpers (do NOT add to Vercel Production) ---

# AUTH_DEV_REGISTER=1
# AUTH_SKIP_RATE_LIMIT=1

# --- Optional scripts ---

# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_ACCESS_TOKEN=sbp_...
# BACKUP_DIR=/Users/you/PayGuard-backups

# E2E: see .env.test.example
