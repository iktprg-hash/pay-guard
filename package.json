{
  "name": "pay-guard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next dev --hostname 127.0.0.1 --port 3000",
    "dev:clean": "rm -rf .next && next dev --hostname 127.0.0.1 --port 3000",
    "dev:restart": "node scripts/restart-dev.mjs",
    "build": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start --hostname 127.0.0.1 --port 3000",
    "start:prod:restart": "node scripts/restart-prod.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:local": "tsx tests/e2e-preflight-cli.ts && E2E_NO_WEBSERVER=1 E2E_PREFLIGHT_DONE=1 playwright test",
    "test:e2e:ci": "node scripts/ci-e2e.mjs",
    "test:e2e:preflight": "tsx tests/e2e-preflight-cli.ts",
    "test:e2e:ui": "E2E_NO_WEBSERVER=1 playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:debug": "E2E_NO_WEBSERVER=1 playwright test --debug",
    "test:e2e:install": "playwright install --with-deps",
    "pwa:assets": "node scripts/generate-icons.mjs && node scripts/generate-splash.mjs",
    "db:apply": "node scripts/apply-migration.mjs",
    "db:apply:003": "node scripts/apply-migration.mjs 003",
    "db:apply:005": "node scripts/apply-migration.mjs 005",
    "db:apply:006": "node scripts/apply-migration.mjs 006",
    "db:apply:008": "node scripts/apply-migration.mjs 008",
    "db:apply:009": "node scripts/apply-migration.mjs 009",
    "db:apply:011": "node scripts/apply-migration.mjs 011",
    "db:sql": "node scripts/print-migration-sql.mjs",
    "db:apply:pro": "node scripts/apply-migration.mjs 20260615110800",
    "db:verify": "node scripts/verify-migrations.mjs",
    "db:migration-audit": "node scripts/db-migration-audit.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "db:restore": "node scripts/db-restore.mjs",
    "db:hint": "node scripts/db-hint.mjs",
    "auth:setup": "node scripts/auth-setup-checklist.mjs",
    "verify:upstash": "node scripts/verify-upstash.mjs",
    "verify:stripe": "node scripts/verify-stripe.mjs",
    "verify:webhook": "node scripts/verify-webhook.mjs",
    "stage2:check": "npm run verify:stripe && npm run verify:webhook",
    "fix:subscription-expires:dry": "node scripts/fix-null-subscription-expires.mjs --dry-run",
    "fix:subscription-expires": "node scripts/fix-null-subscription-expires.mjs",
    "prod:checklist": "node scripts/prod-checklist.mjs",
    "prod:checklist:strict": "node scripts/prod-checklist.mjs --strict",
    "domain:setup": "node scripts/domain-setup.mjs",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.cjs",
    "lighthouse:ci:server": "npm run build && npm run start:prod & sleep 5 && npm run lighthouse:ci"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.58.0",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb-keyval": "^6.2.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.5.11",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pg": "^8.21.0",
    "sharp": "^0.35.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
